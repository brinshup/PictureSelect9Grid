# 通义千问 Qwen3-VL-Plus API 密钥
# 从 https://dashscope.aliyun.com/ 获取
QWEN_API_KEY=sk-你的密钥

# API 端点（国内版默认，国际版请改为 https://dashscope.aliyuncs.com/compatible-mode/v1）
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# 模型名称
QWEN_MODEL=qwen3-vl-plus

# 最大并发请求数（建议 5-15）
QWEN_MAX_CONCURRENCY=10
